# Configure your local AI CLI commands here.
# These are shell commands. Keep quotes.

AGY_CMD='agy'
CLAUDE_CMD='claude'
CODEX_CMD='codex'

# Put your CM CLI / DeepSeek Codex command here.
# Examples:
# DEEPSEEK_CMD='codex'
# DEEPSEEK_CMD='cm'
# DEEPSEEK_CMD='codex --model deepseek/deepseek-v4-flash'
DEEPSEEK_CMD='codex'

# tmux session name. If empty, swarm-start generates one from the folder name.
SWARM_SESSION=''

# Set to 1 to paste the boot prompt automatically after each CLI starts.
# Set to 0 if your CLI needs manual login/onboarding first.
SWARM_AUTO_BOOT='1'
