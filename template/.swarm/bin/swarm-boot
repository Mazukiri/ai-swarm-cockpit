#!/usr/bin/env bash
set -euo pipefail

if [[ ! -f .swarm/runtime/panes.json ]]; then
  echo "No .swarm/runtime/panes.json found. Start the swarm first." >&2
  exit 1
fi

python3 - <<'PY'
import json
import subprocess
import time
import uuid
from pathlib import Path

ROOT = Path('.')
panes = json.loads(Path('.swarm/runtime/panes.json').read_text())
QUEUE = ROOT / '.swarm' / 'queue'
QUEUE.mkdir(parents=True, exist_ok=True)

# Detect exec-loop agents: those whose command starts with "codex"
def get_exec_agents():
    env_file = ROOT / '.swarm' / 'agents.env'
    exec_set = set()
    if not env_file.exists():
        return exec_set
    for line in env_file.read_text().splitlines():
        line = line.strip()
        if not line or line.startswith('#') or '=' not in line:
            continue
        key, _, val = line.partition('=')
        val = val.strip().strip('"\'')
        if key.strip().endswith('_CMD') and val.startswith('codex'):
            exec_set.add(key.strip()[:-4].lower())
    return exec_set

exec_agents = get_exec_agents()

agents = ['agy', 'claude', 'codex', 'deepseek']
for agent in agents:
    pane = panes.get(agent)
    prompt_path = Path(f'.swarm/prompts/{agent}.md')
    if not pane or not prompt_path.exists():
        continue
    prompt = prompt_path.read_text(encoding='utf-8')

    if agent in exec_agents:
        # Exec-loop agents boot themselves on startup — skip paste, nothing to do
        print(f'[boot] {agent.upper()}: exec-loop agent, boot handled by agent-exec-loop')
        continue

    text = f"""Read AI_COLLAB.md and .swarm/prompts/{agent}.md. You are running inside AI Swarm Cockpit.

Important communication commands available in this project:
- say agy "message"
- say claude "message"
- say codex "message"
- say deepseek "message"
- broadcast "message"

Your specific role prompt:

{prompt}

Acknowledge your role by sending a short message to AGY using the say command. Do not start editing files until AGY assigns or confirms a task.
"""
    buf = f'swarm_boot_{agent}'
    subprocess.run(['tmux', 'set-buffer', '-b', buf, text], check=True)
    subprocess.run(['tmux', 'paste-buffer', '-d', '-b', buf, '-t', pane], check=True)
    time.sleep(0.3)
    subprocess.run(['tmux', 'send-keys', '-t', pane, 'C-m'], check=True)
    print(f'[boot] {agent.upper()}: paste-boot sent')
PY
