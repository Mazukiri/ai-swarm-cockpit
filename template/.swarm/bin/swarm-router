#!/usr/bin/env python3
import json
import os
import subprocess
import sys
import time
import uuid
from pathlib import Path

ROOT = Path.cwd()
SWARM = ROOT / ".swarm"
RUNTIME = SWARM / "runtime"
MESSAGES = SWARM / "messages.jsonl"
DELIVERED = RUNTIME / "delivered.json"
PANES = RUNTIME / "panes.json"
CHAT = SWARM / "chat.log"
QUEUE = SWARM / "queue"

AGENTS = ["agy", "claude", "codex", "deepseek"]

# Agents using codex exec-loop (not interactive TUI paste)
# These receive messages via queue files, not tmux paste-buffer
EXEC_AGENTS: set[str] = set()


def detect_exec_agents() -> set[str]:
    """Read agents.env and mark any agent whose command starts with 'codex' as exec agent."""
    env_file = SWARM / "agents.env"
    if not env_file.exists():
        return set()
    exec_set: set[str] = set()
    for line in env_file.read_text(encoding="utf-8").splitlines():
        line = line.strip()
        if not line or line.startswith("#"):
            continue
        if "=" not in line:
            continue
        key, _, val = line.partition("=")
        key = key.strip()
        val = val.strip().strip("'\"")
        if key.endswith("_CMD") and val.startswith("codex"):
            agent = key[: -len("_CMD")].lower()
            exec_set.add(agent)
    return exec_set


def log(line: str) -> None:
    ts = time.strftime("%Y-%m-%dT%H:%M:%S")
    with CHAT.open("a", encoding="utf-8") as f:
        f.write(f"[{ts}] ROUTER: {line}\n")


def load_json(path: Path, default):
    if not path.exists():
        return default
    try:
        return json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        return default


def save_json(path: Path, data) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(data, ensure_ascii=False, indent=2), encoding="utf-8")


def tmux_paste(pane: str, text: str) -> None:
    # Use a dedicated buffer to avoid shell quoting issues and preserve Unicode/newlines.
    buffer_name = f"swarm_msg_{int(time.time() * 1000)}"
    subprocess.run(["tmux", "set-buffer", "-b", buffer_name, text], check=True)
    subprocess.run(["tmux", "paste-buffer", "-d", "-b", buffer_name, "-t", pane], check=True)
    # Small delay so paste content arrives before Enter fires (race condition fix)
    time.sleep(0.3)
    subprocess.run(["tmux", "send-keys", "-t", pane, "C-m"], check=True)


def deliver_via_queue(agent: str, text: str) -> None:
    """Write message to agent's queue directory for exec-loop pickup."""
    QUEUE.mkdir(parents=True, exist_ok=True)
    # Filename: {agent}_{timestamp_ms}_{uuid4[:8]}.msg — sorts by arrival time
    filename = f"{agent}_{int(time.time() * 1000):016d}_{uuid.uuid4().hex[:8]}.msg"
    msg_file = QUEUE / filename
    # Atomic write via temp file + rename
    tmp = msg_file.with_suffix(".tmp")
    tmp.write_text(text, encoding="utf-8")
    tmp.rename(msg_file)


def build_incoming_prompt(msg: dict, target: str) -> str:
    sender = msg.get("from", "unknown")
    body = msg.get("message", "")
    return f"""[SWARM MESSAGE]
From: {sender.upper()}
To: {target.upper()}

{body}

Instructions:
- Treat this as a live message from another agent or the human.
- If you need to reply, run: say {sender} "your reply".
- If you need another agent, run: say <agy|claude|codex|deepseek> "your message".
- If you start editing files, claim them in .swarm/LOCKS.md or announce the claim with say/broadcast.
[/SWARM MESSAGE]"""


def read_messages() -> list[dict]:
    if not MESSAGES.exists():
        return []
    out = []
    with MESSAGES.open("r", encoding="utf-8") as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            try:
                out.append(json.loads(line))
            except json.JSONDecodeError:
                continue
    return out


def route_once() -> None:
    panes = load_json(PANES, {})
    delivered = set(load_json(DELIVERED, []))
    changed = False

    for msg in read_messages():
        mid = msg.get("id")
        if not mid or mid in delivered:
            continue

        sender = str(msg.get("from", "human")).lower()
        target = str(msg.get("to", "")).lower()

        if target == "all":
            targets = [a for a in AGENTS if a != sender]
        else:
            targets = [target]

        ok = True
        for t in targets:
            pane = panes.get(t)
            if not pane:
                log(f"Cannot deliver {mid}: no pane for {t.upper()}")
                ok = False
                continue
            prompt = build_incoming_prompt(msg, t)
            try:
                if t in EXEC_AGENTS:
                    deliver_via_queue(t, prompt)
                    log(f"Queued {mid} from {sender.upper()} to {t.upper()} (exec-loop)")
                else:
                    tmux_paste(pane, prompt)
                    log(f"Delivered {mid} from {sender.upper()} to {t.upper()}")
            except Exception as e:
                log(f"Failed delivering {mid} to {t.upper()}: {e}")
                ok = False

        # Mark delivered even if one pane failed, otherwise a bad pane can spam forever.
        delivered.add(mid)
        changed = True

    if changed:
        save_json(DELIVERED, sorted(delivered))


def main() -> int:
    global EXEC_AGENTS
    RUNTIME.mkdir(parents=True, exist_ok=True)
    QUEUE.mkdir(parents=True, exist_ok=True)
    MESSAGES.touch(exist_ok=True)
    CHAT.touch(exist_ok=True)
    EXEC_AGENTS = detect_exec_agents()
    log("Router started")
    print("AI Swarm Router started. Press Ctrl+C to stop.")
    print(f"Project: {ROOT}")
    print(f"Messages: {MESSAGES}")
    if EXEC_AGENTS:
        print(f"Exec-loop agents (queue delivery): {', '.join(sorted(EXEC_AGENTS))}")
    while True:
        route_once()
        time.sleep(1)


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except KeyboardInterrupt:
        log("Router stopped")
        print("\nRouter stopped")
        raise SystemExit(0)
